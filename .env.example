# Copy this file to .env.local and fill in values from:
# Firebase Console → Project settings → Your apps → Web app → SDK setup and configuration

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Surveillance Backend ──────────────────────────────────────────────────────
# FastAPI backend deployed on Cloud Run (camera REST API + WebSocket AI events)
# Set this to your Cloud Run service URL — NO trailing slash
NEXT_PUBLIC_SURVEILLANCE_API_URL=https://axora-765938782391.europe-west1.run.app

# go2rtc WebRTC Gateway (self-hosted on-premises or a VM — NOT Cloud Run)
# This must be reachable from the browser. Set to your go2rtc instance IP.
# e.g. http://192.168.1.100:1984
NEXT_PUBLIC_GO2RTC_URL=http://localhost:1984

# ─── Notes ────────────────────────────────────────────────────────────────────
# Required in Firebase Console (project mooneychat):
# Authentication → Get started → Sign-in method → Email/Password → Enable → Save
# Without this, sign-up/login fails with auth/configuration-not-found

# After enabling Auth, deploy Firestore rules (fixes "Missing or insufficient permissions"):
# npm run firebase:deploy:rules
# Or paste firestore.rules into Firebase Console → Firestore → Rules → Publish
#
# Paystack sandbox public key (Dashboard → Settings → API Keys → Test Public Key)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Composite indexes for dashboard queries (fixes "The query requires an index"):
# npm run firebase:deploy:indexes
# Or click the link in the browser console error to create each index
