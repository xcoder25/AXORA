rules_version = '2';

// Deploy to project "mooneychat":
//   firebase deploy --only firestore:rules
// Or paste into Firebase Console → Firestore → Rules → Publish

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function callerProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasCallerProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function callerSchoolId() {
      return callerProfile().data.schoolId;
    }

    function isSchoolStaff() {
      return hasCallerProfile()
        && callerProfile().data.role in ['admin', 'teacher'];
    }

    function isSameSchoolAsCaller() {
      return hasCallerProfile()
        && resource.data.schoolId == callerSchoolId();
    }

    // Deploy institution: admin creates school; parents can verify ID before sign-up
    match /schools/{schoolId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.adminUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.adminUid == request.auth.uid;
      allow delete: if false;
    }

    match /users/{userId} {
      allow get: if isSelf(userId)
        || (isSchoolStaff() && isSameSchoolAsCaller());
      allow list: if isSchoolStaff() && isSameSchoolAsCaller();

      // Self sign-up (e.g. parent portal) OR admin enrolling a new student/teacher
      allow create: if
        // Normal self sign-up
        (isSelf(userId) && request.resource.data.uid == userId)
        // Admin enrolling a student or teacher under their school
        || (isSchoolStaff()
            && request.resource.data.schoolId == callerSchoolId()
            && request.resource.data.uid == userId);

      allow update: if isSelf(userId)
        || (isSchoolStaff() && isSameSchoolAsCaller());
      allow delete: if false;
    }

    match /attendance/{recordId} {
      allow read, write: if isSignedIn();
    }

    match /finance/{recordId} {
      allow read, write: if isSignedIn();
    }

    match /exams/{examId} {
      allow read, write: if isSignedIn();
    }

    match /workflows/{workflowId} {
      allow read, write: if isSignedIn();
    }

    match /announcements/{annId} {
      allow read, write: if isSignedIn();
    }

    // Outbox: email dispatch audit log written by admins/teachers
    match /outbox/{docId} {
      allow create: if isSchoolStaff();
      allow read: if isSchoolStaff();
      allow update, delete: if false;
    }

    // Camera registry (surveillance backend)
    match /cameras/{cameraId} {
      allow read, write: if isSchoolStaff();
    }
  }
}
