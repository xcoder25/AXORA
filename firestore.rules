rules_version = '2';

// Deploy to project "mooneychat":
//   firebase deploy --only firestore:rules
// Or paste into Firebase Console → Firestore → Rules → Publish

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Deploy institution: admin creates school; parents can verify ID before sign-up
    match /schools/{schoolId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.adminUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.adminUid == request.auth.uid;
      allow delete: if false;
    }

    match /users/{userId} {
      allow get: if isSelf(userId);
      allow list: if isSignedIn();
      allow create: if isSelf(userId)
        && request.resource.data.uid == userId;
      allow update: if isSelf(userId);
      allow delete: if false;
    }

    match /attendance/{recordId} {
      allow read, write: if isSignedIn();
    }

    match /finance/{recordId} {
      allow read, write: if isSignedIn();
    }

    match /exams/{examId} {
      allow read, write: if isSignedIn();
    }

    match /workflows/{workflowId} {
      allow read, write: if isSignedIn();
    }

    match /announcements/{annId} {
      allow read, write: if isSignedIn();
    }
  }
}
