
{
  "entities": {
    "School": {
      "title": "Educational Institution",
      "description": "Comprehensive institutional data for multi-tenancy and SaaS configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "type": { "type": "string", "enum": ["Primary", "Secondary", "Nursery", "Tertiary", "Combined"] },
        "ownership": { "type": "string", "enum": ["Private", "Public"] },
        "mission": { "type": "string" },
        "yearEstablished": { "type": "number" },
        "motto": { "type": "string" },
        "logoUrl": { "type": "string" },
        "contact": {
          "type": "object",
          "properties": {
            "officialEmail": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "altPhone": { "type": "string" },
            "website": { "type": "string" },
            "social": {
              "type": "object",
              "properties": {
                "facebook": { "type": "string" },
                "instagram": { "type": "string" },
                "linkedin": { "type": "string" }
              }
            }
          }
        },
        "location": {
          "type": "object",
          "properties": {
            "country": { "type": "string" },
            "state": { "type": "string" },
            "city": { "type": "string" },
            "address": { "type": "string" },
            "postalCode": { "type": "string" },
            "timeZone": { "type": "string" }
          }
        },
        "academicStructure": {
          "type": "object",
          "properties": {
            "system": { "type": "string", "enum": ["Term System", "Semester System"] },
            "count": { "type": "number", "description": "Number of terms or semesters" },
            "levels": { "type": "array", "items": { "type": "string" } }
          }
        },
        "capacity": {
          "type": "object",
          "properties": {
            "expectedPopulation": { "type": "number" },
            "currentStudentCount": { "type": "number" },
            "teacherCount": { "type": "number" },
            "campusCount": { "type": "number" }
          }
        },
        "branding": {
          "type": "object",
          "properties": {
            "portalName": { "type": "string" },
            "subdomain": { "type": "string" },
            "primaryColor": { "type": "string" },
            "secondaryColor": { "type": "string" }
          }
        },
        "finance": {
          "type": "object",
          "properties": {
            "currency": { "type": "string" },
            "method": { "type": "string" },
            "gateway": { "type": "string" }
          }
        },
        "security": {
          "type": "object",
          "properties": {
            "twoFactor": { "type": "boolean" },
            "backupFrequency": { "type": "string", "enum": ["Daily", "Weekly", "Monthly"] }
          }
        },
        "modules": { "type": "array", "items": { "type": "string" } },
        "adminUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUid"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user information, school affiliation, and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolId": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "teacher", "student", "parent"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "schoolId"]
    },
    "Fee": {
      "title": "Fee Structure",
      "description": "Defines cost categories for the institution.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "schoolId": { "type": "string" }
      },
      "required": ["id", "name", "amount", "schoolId"]
    },
    "Invoice": {
      "title": "Student Invoice",
      "description": "Financial record for a specific student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentUid": { "type": "string" },
        "feeName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "outstanding", "overdue"] },
        "dueDate": { "type": "string", "format": "date" },
        "schoolId": { "type": "string" }
      },
      "required": ["id", "studentUid", "amount", "status", "schoolId"]
    },
    "Announcement": {
      "title": "Campus Announcement",
      "description": "Institutional broadcast message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "senderUid": { "type": "string" },
        "targetRole": { "type": "string" },
        "schoolId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "schoolId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Institutional records."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles with school affiliation."
    },
    "/fees/{feeId}": {
      "schema": "Fee",
      "description": "School fee categories."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Financial transactions."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Broadcasting data."
    }
  }
}
