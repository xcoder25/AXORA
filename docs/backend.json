
{
  "entities": {
    "School": {
      "title": "Educational Institution",
      "description": "Comprehensive institutional data for multi-tenancy and SaaS configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "shortName": { "type": "string" },
        "type": { "type": "string", "enum": ["Primary", "Secondary", "Nursery", "Tertiary", "Combined"] },
        "academicRules": {
          "type": "object",
          "properties": {
            "gradingSystem": { "type": "string", "enum": ["A-F", "GPA", "Percentages", "Custom"] },
            "promotionThreshold": { "type": "number", "description": "Minimum average for auto-promotion" }
          }
        },
        "financeConfig": {
          "type": "object",
          "properties": {
            "currency": { "type": "string" },
            "feeCategories": { "type": "array", "items": { "type": "string" } }
          }
        },
        "adminUid": { "type": "string" }
      },
      "required": ["id", "name", "adminUid"]
    },
    "FeeRecord": {
      "title": "Financial Ledger",
      "description": "Granular fee tracking with splitting and discounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "schoolId": { "type": "string" },
        "splits": {
          "type": "object",
          "properties": {
            "tuition": { "type": "number" },
            "exams": { "type": "number" },
            "pta": { "type": "number" },
            "transport": { "type": "number" }
          }
        },
        "totalDue": { "type": "number" },
        "amountPaid": { "type": "number" },
        "discountApplied": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Partial", "Paid", "Overdue"] },
        "dueDate": { "type": "string", "format": "date-time" }
      }
    },
    "SmartWorkflow": {
      "title": "Automation Workflow",
      "description": "If-Then logic for school automation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trigger": { "type": "string", "enum": ["Absence", "FeeOverdue", "ResultPublished"] },
        "action": { "type": "string", "enum": ["SMS", "WhatsApp", "Email", "Push"] },
        "recipient": { "type": "string", "enum": ["Parent", "Student", "Staff"] },
        "frequency": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user information, school affiliation, and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolId": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "teacher", "student", "parent", "security"]
        }
      },
      "required": ["uid", "email", "role", "schoolId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Institutional records."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/finance/{recordId}": {
      "schema": "FeeRecord",
      "description": "Financial ledger entries."
    },
    "/workflows/{workflowId}": {
      "schema": "SmartWorkflow",
      "description": "Automation task definitions."
    }
  }
}
