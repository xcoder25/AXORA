
{
  "entities": {
    "School": {
      "title": "Educational Institution",
      "description": "Stores institutional data and configuration for multi-tenancy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUid"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user information, school affiliation, and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolId": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "teacher", "student"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "schoolId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Institutional records."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles with school affiliation."
    }
  }
}
