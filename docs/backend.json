
{
  "entities": {
    "School": {
      "title": "Educational Institution",
      "description": "Stores institutional data and configuration for multi-tenancy.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminUid"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user information, school affiliation, and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "schoolId": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["admin", "teacher", "student", "parent"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "schoolId"]
    },
    "Fee": {
      "title": "Fee Structure",
      "description": "Defines cost categories for the institution.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "schoolId": { "type": "string" }
      },
      "required": ["id", "name", "amount", "schoolId"]
    },
    "Invoice": {
      "title": "Student Invoice",
      "description": "Financial record for a specific student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentUid": { "type": "string" },
        "feeName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "outstanding", "overdue"] },
        "dueDate": { "type": "string", "format": "date" },
        "schoolId": { "type": "string" }
      },
      "required": ["id", "studentUid", "amount", "status", "schoolId"]
    },
    "Announcement": {
      "title": "Campus Announcement",
      "description": "Institutional broadcast message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "senderUid": { "type": "string" },
        "targetRole": { "type": "string" },
        "schoolId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "schoolId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "Institutional records."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles with school affiliation."
    },
    "/fees/{feeId}": {
      "schema": "Fee",
      "description": "School fee categories."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Financial transactions."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Broadcasting data."
    }
  }
}
